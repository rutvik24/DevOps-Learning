# Server
PORT=8080
ENV=development

# Database (dev: docker-compose postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=todo
DB_PASSWORD=todo
DB_NAME=todo
DB_SSLMODE=disable

# Prod: set DATABASE_URL instead (RDS)
# DATABASE_URL=postgres://user:pass@your-rds-host:5432/todo?sslmode=require

# CORS
CORS_ORIGIN=http://localhost:3000
